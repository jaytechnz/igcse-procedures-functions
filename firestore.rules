rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: stores role (teacher/student) and email
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        resource.data.role == 'teacher' ||
        resource.data.teacherUid == request.auth.uid
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null &&
        resource.data.teacherUid == request.auth.uid;
    }

    // Progress collection: stores task progress and quiz data per student
    match /progress/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(userId)).data.teacherUid == request.auth.uid
      );
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(userId)).data.teacherUid == request.auth.uid;
    }
  }
}
